}


# --- Amazing ALL method: idor+sql url path+post method+originIp sql bypass+git+env disclosure ---

all_attacks() {

    log_info "FFUF search for vulnerabilities on data/subdomains/HOSTS.alive.subdomains.interesting.db"

#   safe_host=$(echo "$host" | sed 's/http:\\/\\///g; s/https:\\/\\///g; s/\\//_/g')

    cat data/subdomains/HOSTS.alive.subdomains.interesting.db | \
        while read host ; \
            do \
                ffuf -u $host/FUZZ \
		-w $HOME/genesis/db/all_attacks.txt:FUZZ \
		-H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0" \
		-c \
		-t 200 \
		-rate 250 \
		-p 2 \
		-mc 200 \
               	-recursion \
		-recursion-depth 3 \
		-od reports/all_attacks/html \
		-of json \
		-o reports/all_attacks/$host.json \
	; done

    jq -C ".results[] | select(.status=="200") | .url, .resultfile" reports/discovery/all_attacks/*.json | tr -d '"'

    echo 'find reports/all_attacks/html -type f -name 'RESULTFILE' | xargs -I {} firefox-esr {}'
#   find reports/all_attacks/html -type f -name 41cadd3d77b3b4a7185453b6608e0635 | xargs -I {} firefox-esr {}

#   -e \ asp,aspx,bat,c,cfm,cgi,css,com,dll,exe,hta,htm,html,inc,jhtml,js,jsa,json,jsp,log,mdb,nsf,pcap,php,php2,php3,php4,php5,php6,php7,phps,pht,phtml,pl,phar,rb,rb~,reg,sh,shtml,sql,swf,txt,xml,conf,config,bak,bkp,backup,swp,swp~,old,db,rar,sql.gz,sql.zip,sql.tar.gz,tar,tar.bz2,tar.gz,py,py~,cache
}



# --- .JS sieve ---

sensitive_js() {

    log_info "Parsing .js files for secrets ---"

    cat data/urls/urls.www.js.db | jsleak -s -l -k | anew reports/discovery/secrets/secrets.js.db
    awk -F "Found link: \[./" '{print $2}' reports/discovery/secrets/secrets.js.db | cut -d ']' -f 1 | sed '/^[[:space:]]*$/d' | sed 's/$/\//g' | anew data/urls/urls.www.subdirectories.js.db
    grep "Found link: \[" reports/discovery/secrets/secrets.js.db | awk -F "\[\/" '{print $2}' | grep '/]' | cut -d ']' -f 1 | anew data/urls/urls.www.subdirectories.js.db

    nuclei -list data/urls/urls.www.js.db -vv -c 25 -rl 500 -t ~/nuclei-templates/http/exposures -o reports/discovery/secrets/exposures.js.db
    nuclei -list data/urls/urls.www.js.db -vv -c 25 -rl 500 -t ~/genesis/nuclei/credentials-disclosure-all.yaml -o reports/discovery/secrets/credentials-disclosure-all.js.db

    cat data/urls/urls.www.js.db | httpx -er "(?:(https?|ftp|git|ssh|telnet|smtp|imap|pop3|ldap|sftp|smb|nfs|rtmp|rtsp|ws|wss|irc|news|gopher|rsync|data):\/\/|\/)[^\s\"'\*\(\){};\\\^\$\&<>/\\?#]+(?:\?[^\s\"'<>/\\?#]+)?(?:\/[^\s\"'<>/\\?#]+)*" -json -mr "application/javascript|text/javascript" | jq -r '.extracts[]' | tr -d '[],' | tee reports/discovery/secrets/protocol.js.db

    # grep "target.com\|targ.co" reports/discovery/secrets/protocol.js.db | cut -d '"' -f2 | cut -d '"' -f1 | anew reports/discovery/secrets/protocol.host.js.db
}


# --- s3 buckets discovery ---

bucket() {

    log_info "s3 bucket discovery"

    cat data/urls/urls.www.js.db | xargs -I {} curl -s {} | grep -Eo 'http[s]?://[^"]*.s3.amazonaws.com' | sort -u | anew reports/discovery/bucket/s3-disclosures.db
    cat data/urls/urls.www.js.db | xargs -I {} curl -s {} | grep -Eo 'http[s]?://[^"]*\.s3\.amazonaws\.com[^" ]*' | sort -u | anew reports/discovery/bucket/s3-disclosures.db
    nuclei -list data/urls/urls.www.js.db -vv -c 25 -rl 500 -t ~/genesis/nuclei/awspace.yaml -o reports/discovery/bucket/awspace.js.db
}


# --- Run nuclei on HOSTS.alive.db ---

nuclei_scan() {

    log_info "Nuclei scanning on HOSTS.alive.db"

#   Target HOSTS.alive.db
    nuclei -list data/subdomains/HOSTS.alive.db -vv -c 25 -rl 500 -fhr -t ~/genesis/nuclei -o data/nuclei/genesis.db
    nuclei -list data/subdomains/HOSTS.alive.db -vv -c 25 -rl 500 -severity medium,high,critical -fhr -t ~/nuclei-templates/http/cves -o data/nuclei/cves.db
    nuclei -list data/subdomains/HOSTS.alive.db -vv -c 25 -rl 500 -severity medium.high,critical -fhr -t ~/nuclei-templates/http/exposures -o data/nuclei/exposures.db
    nuclei -list data/subdomains/HOSTS.alive.db -vv -c 25 -rl 500 -severity medium,high,critical -fhr -t ~/nuclei-templates/http/vulnerabilities/generic -o data/nuclei/generic.db

#   Target gau-urls.www.db
    nuclei -list data/urls/urls.www.db -vv -c 25 -rl 500 -t ~/genesis/nuclei -o data/nuclei/genesis-urls.db
    nuclei -list data/urls/urls.www.db -vv -c 25 -rl 500 -severity medium,high,critical -t ~/nuclei-templates/dast/vulnerabilities -dast -o data/nuclei/dast-urls.db
}


# --- Main function: flowstream ---

main() {

    cd "$ASSET"
    selection
}

# --- Main Execute

main