set -e

# --- Configuration ---

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m' # No Color

# --- Paths ---

ASSET="$HOME/BLACKSITES/$HOST"
readonly BLACKSITES="$HOME/BLACKSITES"
readonly DEBIAN_FRONTEND=noninteractive

# --- Helper Functions ---

log_info() {
    printf "${GREEN}[+] $1 ${NC}\n"
}

log_warn() {
    printf "${YELLOW}[-] $1 ${NC}\n"
}

log_err() {
    printf "${RED}[!] $1 ${NC}\n" >&2
}


# --- Recon toolkit ---

selection() {

    log_info "Recon toolkit: Selection to continue"
    PS3="Please select an option : "
    choices=("ASSEMBLE" "PARSE_ADMIN" "PARSE_FULL" "SENSITIVE_ADMIN" "SENSITIVE_FULL" "ALL_attacks" "JS" "BUCKET" "NUCLEI" "Exit")
    select choice in "${choices[@]}"; 
        do
            case $choice in
                ASSEMBLE)
                     assemble_interesting_subdomains
                     sleep 1
                     exit 1
                     ;;
                PARSE_ADMIN)
                     parse_admin_scan
                     sleep 1
                     exit 1
                     ;;
                PARSE_FULL)
                     parse_full_scan
                     sleep 1
                     exit 1
                     ;;
                SENSITIVE_ADMIN)
                     sensitive_admin
                     sleep 1
                     exit 1
                     ;;
                SENSITIVE_FULL)
                     sensitive_full
                     sleep 1
                     exit 1
                     ;;
                ALL_attacks)
                     all_attacks
                     sleep 1
                     exit 1
                     ;;
                JS)
                     sensitive_js
                     sleep 1
                     exit 1
                     ;;
                BUCKET)
                     bucket
                     sleep 1
                     exit 1
                     ;;
                NUCLEI)
                     nuclei_scan
                     sleep 1
                     exit 1
                     ;;
                Exit)
                     echo "Aborting script..."
                     exit 1
                     ;;
            esac
        done
}


# --- Interesting subdomains ---

assemble_interesting_subdomains() {

    log_info "Assembling list of interesting subdomains"

    cat data/subdomains/HOSTS.alive.db | grep -E "admin|administrator|root|sysadmin|secure|api|gateway|auth|login|sso|dev|developer|test|stage|staging|uat|beta|demo|internal|intranet|vpn|portal|dashboard|manage|management|config|control|server|db|database|backup|files|static|cdn" | anew data/subdomains/HOSTS.alive.subdomains.interesting.db

    wc -l data/subdomains/HOSTS.alive.subdomains.interesting.db
}


# --- Run parsing enumeration on data/subdomains/HOSTS.alive.subdomains.interesting.db - ADMIN ---

parse_admin_scan() {

    log_info "Parsing enumeration on data/subdomains/HOSTS.alive.subdomains.interesting.db"

#   cat data/subdomains/HOSTS.alive.subdomains.interesting.db | gau | uro | anew data/urls/urls.www.db
    cat data/subdomains/HOSTS.alive.subdomains.interesting.db | katana -d 3 -c 50 -silent -f qurl -ignore-query-params -filter-similar -disable-redirects -jc -kf all -aff | uro | anew data/urls/urls.www.db

    cat data/urls/urls.www.db | grep -E "(admin/|administrator/|root/|sysadmin/|secure/|api/|gateway/|auth/|login/|sso/|dev/|developer/|test/|stage/|staging/|uat/|beta/|demo/|internal/|intranet/|vpn/|portal/|dashboard/|manage/|management/|config/|control/|server/|db/|database/|backup/|files/|static/|cdn/|wp-admin/)" | cut -d '/' -f 1,2,3,4 | unfurl domain | anew data/urls/urls.www.subdirectories.interesting.db

    grep -Eo 'https?://[^"]+' data/urls/urls.www.db | grep -Eo '[^*]*/' | cut -d '/' -f 4 | sed '/^[[:space:]]*$/d' | anew data/urls/urls.www.subdirectories.listing.db

    grep -E '\.js($|\?.*)' data/urls/urls.www.db | awk -F '?' '{print $1}' | httpx -mc 200 | sort -u | anew data/urls/urls.www.js.db

    grep -Ev '\.js($|\?.*)' data/urls/urls.www.db | grep -E '\?[^=]+=.+$' | grep '=' | qsreplace | anew data/urls/urls.www.params.db
    grep -Eo 'https?://[^"]+' data/urls/urls.www.db | cut -d '/' -f 1,2,3,4 | grep '/?' | qsreplace | anew data/urls/urls.www.params.db

    grep 'robots.txt' data/urls/urls.www.db | anew data/urls/robots.txt.db
}


# --- Run parsing enumeration on HOSTS.alive.db - FULL ---

parse_full_scan() {

    log_info "Parsing enumeration on HOSTS.alive.db"

#   cat data/subdomains/HOSTS.alive.db | gau | uro | anew data/urls/urls.www.db
    cat data/subdomains/HOSTS.alive.db | katana -d 3 -c 50 -silent -f qurl -ignore-query-params -filter-similar -disable-redirects -jc -kf all -aff | uro | anew data/urls/urls.www.db

    cat data/urls/urls.www.db | grep -E "(admin/|administrator/|root/|sysadmin/|secure/|api/|gateway/|auth/|login/|sso/|dev/|developer/|test/|stage/|staging/|uat/|beta/|demo/|internal/|intranet/|vpn/|portal/|dashboard/|manage/|management/|config/|control/|server/|db/|database/|backup/|files/|static/|cdn/|wp-admin/)" | cut -d '/' -f 1,2,3,4 | unfurl domain | anew data/urls/urls.www.subdirectories.interesting.db

    grep -Eo 'https?://[^"]+' data/urls/urls.www.db | grep -Eo '[^*]*/' | cut -d '/' -f 4 | sed '/^[[:space:]]*$/d' | anew data/urls/urls.www.subdirectories.listing.db

    grep -E '\.js($|\?.*)' data/urls/urls.www.db | awk -F '?' '{print $1}' | httpx -mc 200 | sort -u | anew data/urls/urls.www.js.db

    grep -Ev '\.js($|\?.*)' data/urls/urls.www.db | grep -E '\?[^=]+=.+$' | grep '=' | qsreplace | anew data/urls/urls.www.params.db
    grep -Eo 'https?://[^"]+' data/urls/urls.www.db | cut -d '/' -f 1,2,3,4 | grep '/?' | qsreplace | anew data/urls/urls.www.params.db

    grep 'robots.txt' data/urls/urls.www.db | anew data/urls/robots.txt.db
}


#   Run FFUF for Sensitive content discovery - ADMIN ---

sensitive_admin() {

    log_info "FFUF search for sensitive files/directories on data/urls/urls.www.subdirectories.interesting.db"

#   safe_host=$(echo "$host" | sed 's/http:\\/\\///g; s/https:\\/\\///g; s/\\//_/g')

    cat data/urls/urls.www.subdirectories.interesting.db | \
        while read host ; \
            do \
                ffuf -u https://$host/FUZZ \
		-w $HOME/genesis/db/sensitive.lst:FUZZ \
		-H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0" \
		-c \
		-t 200 \
		-rate 250 \
		-p 2 \
		-fc 400-402,404-499,500-599 \
		-recursion \
		-recursion-depth 2 \
		-od reports/discovery/html \
		-of json \
		-o reports/discovery/$host.json \
	; done

    jq -C ".results[] | select(.status=="200") | .url, .resultfile" reports/discovery/*.json | tr -d '"'

    echo 'find reports/discovery/html -type f -name 'RESULTFILE' | xargs -I {} firefox-esr {}'
#   find reports/discovery/html -type f -name 41cadd3d77b3b4a7185453b6608e0635 | xargs -I {} firefox-esr {}

#   Analyze Results

#   Check output files for HTTP status codes:
#   200 OK: Endpoint exists (e.g., /config.json might leak API keys).
#   403 Forbidden: Could indicate a protected endpoint worth testing.
#   301/302 Redirect: Test for open redirects (e.g., /redirect with redirectUrl=evil.com).
#   Use Burp Suite Community Edition to inspect promising endpoints (e.g., /service-worker.js, /api/users).
#   For files like service-worker.js, test parameters like redirectUrl for open redirects or XSS using Burp’s Repeater.
}


